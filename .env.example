# Supabase — browser + server (safe to expose, required on client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary — browser (safe to expose)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Obvious External API — server-only (NO NEXT_PUBLIC_ prefix — never expose to the browser)
# Used by POST /api/tasks to proxy instructions to:
#   POST https://api.app.obvious.ai/api/v1/projects/{OBVIOUS_PROJECT_ID}/thread
#
# OBVIOUS_API_KEY  — generate in Obvious: Settings → Workspace → Integrations → External Access
# OBVIOUS_PROJECT_ID — the target project's ID from its Obvious workspace URL
#
# Set both in the Vercel dashboard for Production + Preview.
# For local dev, add them to .env.local (never commit .env.local).
OBVIOUS_API_KEY=
OBVIOUS_PROJECT_ID=

